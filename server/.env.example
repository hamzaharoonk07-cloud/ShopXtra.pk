# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# Database
DATABASE_URL=
# Or, if not using DATABASE_URL:
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Outgoing email (Gmail example — use an App Password, not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=shopxtra9@gmail.com
SMTP_PASS=
MAIL_FROM="ShopXtra" <shopxtra9@gmail.com>

# Image uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# Misc
SITE_URL=https://shop-xtra-pk.vercel.app
PORT=4000
NODE_ENV=development
